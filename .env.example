# Copy this file to .env and fill in your values.
# All variables use the MUSEUMS_ prefix.

# Database
MUSEUMS_DATABASE_URL=postgresql+asyncpg://museums:museums@db:5432/museums
MUSEUMS_DATABASE_ECHO=false

# Refresh policy
MUSEUMS_REFRESH_COOLDOWN_HOURS=24

# HTTP client timeouts (seconds)
MUSEUMS_HTTP_CONNECT_TIMEOUT_SECONDS=5.0
MUSEUMS_HTTP_READ_TIMEOUT_SECONDS=30.0
MUSEUMS_HTTP_MAX_RETRIES=3

# External API endpoints
MUSEUMS_MEDIAWIKI_BASE_URL=https://en.wikipedia.org/w/api.php
MUSEUMS_WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
MUSEUMS_WIKIPEDIA_LIST_PAGE_TITLE=List_of_most_visited_museums

# Data filtering
MUSEUMS_MUSEUM_VISITOR_THRESHOLD=2000000

# Logging
MUSEUMS_LOG_LEVEL=INFO

# HTTP client identity
MUSEUMS_USER_AGENT=MuseumsApp/0.1 (https://github.com/example/museums)
